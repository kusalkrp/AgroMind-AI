# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/gemini-embedding-001

# ── Qdrant ────────────────────────────────────────────────────────────────────
# Inside Docker: use service name "qdrant". Outside Docker: use "localhost".
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=agromind

# ── PostgreSQL / TimescaleDB / PostGIS ────────────────────────────────────────
# Inside Docker: host = "timescaledb". Outside Docker: host = "localhost".
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=agromind
POSTGRES_USER=agromind
POSTGRES_PASSWORD=agromind_secret
POSTGRES_URL=postgresql://agromind:agromind_secret@timescaledb:5432/agromind

# ── Redis ─────────────────────────────────────────────────────────────────────
# Inside Docker: host = "redis". Outside Docker: host = "localhost".
REDIS_URL=redis://redis:6379/0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── MLflow ────────────────────────────────────────────────────────────────────
# Inside Docker: host = "mlflow". Outside Docker: host = "localhost".
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=agromind-eval

# ── LangSmith ────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=agromind-ai

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# ── Ingestion ────────────────────────────────────────────────────────────────
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
MAX_CRAWL_RETRIES=3
CRAWL_BACKOFF_BASE=2

# ── Open-Meteo (free, no key needed) ────────────────────────────────────────
OPENMETEO_BASE_URL=https://archive-api.open-meteo.com/v1/archive
WEATHER_DISTRICTS=Colombo,Kandy,Galle,Jaffna,Anuradhapura,Kurunegala,Ratnapura,Badulla,Trincomalee,Matara
